library(terra)
library(microbenchmark)
# Create test raster (12 layers, 1000x1000 cells)
set.seed(123)
mock_pr_var <- function(n = 1000) {
# Define dimensions
nrows <- n
ncols <- n
# Create empty SpatRaster template using WGS84
r_template <- terra::rast(
nrows = nrows, ncols = ncols,
xmin = -180, xmax = 180,
ymin = -90, ymax = 90,
crs = "EPSG:4326"
)
# Generate 12 monthly rasters with values = month * 100
rasters <- list()
for (month in 1:12) {
r <- r_template
terra::values(r) <- month * 100
rasters[[month]] <- r
}
# Stack into a single SpatRaster
pr_stack <- terra::rast(rasters)
# Assign layer names (like CHELSA convention: pr_01 ... pr_12)
names(pr_stack) <- sprintf("pr_%02d", 1:12)
pr_stack
}
bio_12_terra <- function(pr, filename = "") {
terra::app(x = pr, fun = sum, filename = filename)
}
# Load test data
pr_test <- mock_pr_var(3000)
# Load test data
pr_test <- mock_pr_var(1000)
bio_12(pr_test)
bio_12_terra(pr_test)
bio_12(pr_test)
bio_12_terra(pr_test)
# Compare performance
results <- microbenchmark(
terra_app = bio_12_terra(pr_test, filename=""),
bio_12_optim = bio_12(pr_test, block_factor = 4),
times = 3)
# Compare performance
results <- microbenchmark(
terra_app = bio_12_terra(pr_test, filename=""),
bio_12_optim = bio_12(pr_test),
times = 10)
plot(results)
results

nrows <- n
ncols <- n
# Create empty SpatRaster template using WGS84
r_template <- terra::rast(
nrows = nrows, ncols = ncols,
xmin = -180, xmax = 180,
ymin = -90, ymax = 90,
crs = "EPSG:4326"
)
# Generate 12 monthly rasters with values = month * 100
rasters <- list()
for (month in 1:12) {
r <- r_template
terra::values(r) <- month * 100
rasters[[month]] <- r
}
# Stack into a single SpatRaster
pr_stack <- terra::rast(rasters)
# Assign layer names (like CHELSA convention: pr_01 ... pr_12)
names(pr_stack) <- sprintf("pr_%02d", 1:12)
pr_stack
}
bio_12_terra <- function(pr, filename = "") {
terra::app(x = pr, fun = sum, filename = filename)
}
# Load test data
pr_test <- mock_pr_var(5000)
library(microbenchmark)
# Compare performance
results <- microbenchmark(
terra_app = bio_12_terra(pr_test, filename=""),
bio_12_optim = bio_12_optim_v4_parallel(pr_test, block_factor = 8),
times = 3)
pr_test
pr
bio_12_optim_v4_parallel <- function(pr, filename = "", na_rm = FALSE,
nthreads = parallel::detectCores(),
block_factor = 4,
workers = parallel::detectCores()) {
checkmate::assert_class(pr, "SpatRaster")
checkmate::assert_true(terra::nlyr(pr) == 12)
checkmate::assert_string(filename, null.ok = TRUE)
out <- terra::rast(pr, nlyr = 1)
names(out) <- "bio_12"
terra::readStart(pr)
on.exit(terra::readStop(pr), add = TRUE)
write_info <- terra::writeStart(out, filename, overwrite = TRUE,
n = block_factor * terra::nlyr(pr))
on.exit(try(terra::writeStop(out), silent = TRUE), add = TRUE)
# Prepare parallel plan
plan(multisession, workers = workers)
pr <- terra::wrap(pr)
# Process blocks in parallel
results <- future_lapply(seq_len(write_info$n), function(i) {
v_pr <- terra::readValues(terra::unwrap(pr), row = write_info$row[i],
nrows = write_info$nrows[i],
col = 1, ncols = terra::ncol(pr), mat = TRUE)
fastbioclim:::rcpp_block_sum_openmp(v_pr, na_rm = na_rm, nthreads = nthreads)
})
# Write results back in order
for (i in seq_len(write_info$n)) {
terra::writeValues(out, results[[i]], write_info$row[i], write_info$nrows[i])
}
terra::writeStop(out)
out
}
# Compare performance
results <- microbenchmark(
terra_app = bio_12_terra(pr_test, filename=""),
bio_12_optim = bio_12_optim_v4_parallel(pr_test, block_factor = 8),
times = 3)
ptions(future.globals.maxSize = 10 * 1024^3) # 10 GB
options(future.globals.maxSize = 10 * 1024^3) # 10 GB
# Compare performance
results <- microbenchmark(
terra_app = bio_12_terra(pr_test, filename=""),
bio_12_optim = bio_12_optim_v4_parallel(pr_test, block_factor = 8),
times = 3)
devtools::document()
